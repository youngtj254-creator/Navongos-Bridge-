function doTrack() {
  const id = document.getElementById('trackId').value.trim();
  if (!id) { toast('Enter an order ID', 'err'); return; }
  const steps = [
    { done: true, t: 'Order Placed', d: 'Successfully placed.' },
    { done: true, t: 'Payment Confirmed', d: 'Payment received.' },
    { done: true, t: 'Processing', d: 'Seller is preparing your item.' },
    { done: false, t: 'Shipped', d: 'Package on its way.' },
    { done: false, t: 'Out for Delivery', d: 'Arriving soon.' },
