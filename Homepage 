// ======= CART =======
function addToCart(id, silent) {
  const p = PRODS.find(x => x.id === id);
  const ex = cart.find(x => x.id === id);
  if (ex) ex.q++;
  else cart.push({ id: p.id, n: p.n, e: p.e, s: p.s, p: p.p, q: 1 });
  updateCart();
  if (!silent) { toast('✅ ' + p.n + ' added', 'ok'); document.getElementById('cart-drawer').classList.add('open'); }
}

function updateCart() {
  const body = document.getElementById('cartBody');
  const badge = document.getElementById('cartCount');
  const total = cart.reduce((s, i) => s + i.q, 0);
  badge.style.display = total ? 'flex' : 'none';
  badge.textContent = total;
  if (!cart.length) {
    body.innerHTML = '<div style="text-align:center;padding:40px 0;color:var(--text3)"><div style="font-size:2.5rem;margin-bottom:10px">🛒</div><div>Your cart is empty</div></div>';
    document.getElementById('cartFoot').style.display = 'none';
    return;
  }
  body.innerHTML = cart.map(i => `
    <div class="cart-item">
      <div class="ci-img">${i.e}</div>
      <div class="ci-info">
        <div class="ci-name">${i.n}</div>
        <div class="ci-price">$${(i.p * 1.05 * i.q).toFixed(2)}</div>
        <div class="qty-row">
          <button class="qty-btn" onclick="chQty(${i.id},-1)">−</button>
          <span style="font-size:.8rem;font-weight:700">${i.q}</span>
          <button class="qty-btn" onclick="chQty(${i.id},1)">+</button>
        </div>
      </div>
      <button class="ci-rm" onclick="rmCart(${i.id})">✕</button>
    </div>`).join('');
  const sub = cart.reduce((s, i) => s + i.p * i.q, 0);
  const mk = sub * 0.05, tx = (sub + mk) * 0.02, grand = sub + mk + tx;
  document.getElementById('cartTotals').innerHTML = `
    <div class="tot-row"><span>Subtotal</span><span>$${sub.toFixed(2)}</span></div>
    <div class="tot-row"><span>Markup (5%)</span><span>$${mk.toFixed(2)}</span></div>
    <div class="tot-row"><span>Fee (2%)</span><span>$${tx.toFixed(2)}</span></div>
    <div class="tot-row grand"><span>Total</span><span>$${grand.toFixed(2)}</span></div>`;
  document.getElementById('cartFoot').style.display = 'block';
}

function chQty(id, d) { const i = cart.find(x => x.id === id); if (i) { i.q = Math.max(1, i.q + d); updateCart(); } }
function rmCart(id) { cart = cart.filter(x => x.id !== id); updateCart(); }
