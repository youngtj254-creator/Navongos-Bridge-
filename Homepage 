const SRC_COLORS = { amazon: '#ff9900', ebay: '#e53238', alibaba: '#ff6a00', jumia: '#f68b1e' };

function renderProds(list) {
  shownProds = [...list];
  document.getElementById('prodGrid').innerHTML = list.map(p => {
    const price = (p.p * 1.05).toFixed(0);
    const disc = Math.round((1 - p.p / p.orig) * 100);
    const inW = wishlist.has(p.id);
    return `<div class="pc" id="pc${p.id}" onclick="openItem(${p.id})">
      <div class="pc-glow"></div>
      <div class="pc-inner">
        <div class="pc-img-wrap">
          <span class="src-tag" style="background:${SRC_COLORS[p.s]};color:${p.s==='amazon'||p.s==='jumia'?'#111':'#fff'}">${p.s.charAt(0).toUpperCase()+p.s.slice(1)}</span>
          <button class="wish-btn" onclick="event.stopPropagation();toggleWish(${p.id},this)">${inW ? '❤️' : '🤍'}</button>
          <span class="pc-emoji">${p.e}</span>
        </div>
        <div class="pc-body">
          <div class="pc-brand">${p.b}</div>
          <div class="pc-name">${p.n}</div>
          <div class="pc-stars">${'⭐'.repeat(Math.floor(p.r))} <span>(${p.rv.toLocaleString()})</span></div>
          <div class="pc-foot">
            <div>
              <div class="pc-price">$${price}</div>
              <div class="pc-orig">$${p.orig} <span style="color:#10b981;font-size:.68rem;font-weight:700">−${disc}%</span></div>
            </div>
            <button class="add-btn" onclick="event.stopPropagation();addToCart(${p.id})">+</button>
          </div>
        </div>
      </div>
    </div>`;
  }).join('');

  // 3D tilt
  list.forEach(p => {
    const card = document.getElementById('pc' + p.id);
    if (!card) return;
    card.addEventListener('mousemove', function(e) {
      const r = this.getBoundingClientRect();
      const x = e.clientX - r.left, y = e.clientY - r.top;
      const rx = ((y - r.height/2) / r.height) * 12;
      const ry = ((x - r.width/2) / r.width) * -12;
      const inner = this.querySelector('.pc-inner');
      if (inner) inner.style.transform = `perspective(600px) rotateX(${rx}deg) rotateY(${ry}deg) scale3d(1.03,1.03,1.03)`;
      this.style.setProperty('--gx', ((x/r.width)*100) + '%');
      this.style.setProperty('--gy', ((y/r.height)*100) + '%');
    });
    card.addEventListener('mouseleave', function() {
      const inner = this.querySelector('.pc-inner');
      if (inner) inner.style.transform = '';
    });
  });
}

function filterSrc(el, src) {
