  document.getElementById('authLeftH').textContent = isIn ? 'Welcome Back 👋' : 'Create Account ✨';
  document.getElementById('authLeftP').textContent = isIn
    ? 'Sign back in to access your orders, wishlist and profile.'
    : 'Join 500,000+ shoppers saving big across the world\'s best marketplaces.';
  if (!isIn) goStep(1);
}

function goStep(n) {
  curStep = n;
  for (let i = 1; i <= 3; i++) {
    const panel = document.getElementById('sp' + i);
    const circle = document.getElementById('sc' + i);
    if (panel) panel.classList.toggle('active', i === n);
    if (circle) {
      circle.className = 'step-circle';
      if (i < n) { circle.classList.add('done'); circle.textContent = '✓'; }
      else if (i === n) { circle.classList.add('active'); circle.textContent = i; }
      else circle.textContent = i;
    }
    if (i < 3) {
      const line = document.getElementById('sl' + i);
      if (line) line.classList.toggle('done', i < n);
    }
  }
}

function doSignIn() {
  const email = document.getElementById('siEmail').value.trim();
  const pass = document.getElementById('siPass').value;
  if (!email.includes('@')) { toast('Enter a valid email', 'err'); return; }
  if (!pass) { toast('Enter your password', 'err'); return; }
  finishAuth(email.split('@')[0], email);
}

function socialAuth(provider) { finishAuth(provider + ' User', provider.toLowerCase() + '@social.com'); }

function doSignUp() {
  const pass = document.getElementById('s3pass').value;
  const conf = document.getElementById('s3conf').value;
  if (!pass || pass.length < 8) { toast('Password must be 8+ characters', 'err'); return; }
  if (pass !== conf) { toast('Passwords do not match', 'err'); return; }
  if (!document.getElementById('termsBox').checked) { toast('Please accept the Terms', 'err'); return; }
  const first = document.getElementById('s1first').value.trim() || 'New';
  const last = document.getElementById('s1last').value.trim() || 'User';
  const email = document.getElementById('s1email').value.trim() || 'user@navongo.com';
  finishAuth(first + ' ' + last, email);
  launchConfetti();
}

function finishAuth(name, email) {
  document.getElementById('pName').textContent = name;
  document.getElementById('pEmail').textContent = email;
  document.getElementById('profileBtn').style.display = 'flex';
  document.getElementById('authNavBtn').style.display = 'none';
  nav('home');
  setTimeout(() => toast('👋 Welcome, ' + name + '!', 'ok'), 400);
}

function togglePw(id, btn) {
  const inp = document.getElementById(id);
  if (!inp) return;
  inp.type = inp.type === 'password' ? 'text' : 'password';
  btn.textContent = inp.type === 'password' ? '👁' : '🙈';
}

function checkPass(v) {
  const score = (v.length >= 8 ? 1 : 0) + (v.length >= 12 ? 1 : 0) + (/[A-Z]/.test(v) ? 1 : 0) + (/[0-9]/.test(v) ? 1 : 0) + (/[^a-zA-Z0-9]/.test(v) ? 1 : 0);
  const levels = [
    { w: '0%', c: 'transparent', l: '' },
    { w: '25%', c: '#ef4444', l: 'Weak' },
    { w: '50%', c: '#f59e0b', l: 'Fair' },
    { w: '75%', c: '#0abdc6', l: 'Good' },
    { w: '100%', c: '#10b981', l: 'Strong ✓' }
  ];
  const lv = levels[Math.min(score, 4)];
  const fill = document.getElementById('passFill');
  const lbl = document.getElementById('passLbl');
  if (fill) { fill.style.width = lv.w; fill.style.background = lv.c; }
  if (lbl) { lbl.textContent = lv.l; lbl.style.color = lv.c; }
}

// ======= PROFILE =======
function profTab(el, id) {
