// ======= BRANDS =======
const BCATS = ['All', 'Electronics', 'Fashion', 'Luxury', 'Gaming', 'Home', 'Technology', 'Entertainment', 'Lifestyle', 'Toys'];

function renderBrands() {
  const cr = document.getElementById('bcatRow');
  cr.innerHTML = BCATS.map(c =>
    `<button class="bcat ${c === activeBCat ? 'sel' : ''}" onclick="setBCat('${c}',this)">${c}</button>`).join('');
  drawBrands();
}

function setBCat(c, el) {
  activeBCat = c;
  document.querySelectorAll('.bcat').forEach(b => b.classList.remove('sel'));
  el.classList.add('sel');
  drawBrands();
}

function filterBrands(q) {
  const lq = q.toLowerCase();
  const filtered = BRANDS.filter(b => b.n.toLowerCase().includes(lq) && (activeBCat === 'All' || b.c === activeBCat));
  document.getElementById('brandsGrid').innerHTML = filtered.map(brandCard).join('');
}

function drawBrands() {
  const list = activeBCat === 'All' ? BRANDS : BRANDS.filter(b => b.c === activeBCat);
  document.getElementById('brandsGrid').innerHTML = list.map(brandCard).join('');
  setTimeout(scrollReveal, 50);
}

function brandCard(b) {
  return `<div class="brand-card reveal ${b.fol ? 'followed' : ''}" id="bc${b.id}">
    <div class="brand-em">${b.e}</div>
    <div class="brand-name">${b.n}</div>
    <div class="brand-cat">${b.c}</div>
    <div class="brand-fol">👥 ${b.f} followers</div>
    <button class="fol-btn" onclick="toggleFollow(${b.id},this)">${b.fol ? '✓ Following' : '+ Follow'}</button>
  </div>`;
}

function toggleFollow(id, btn) {
  const b = BRANDS.find(x => x.id === id);
  if (!b) return;
  b.fol = !b.fol;
  const card = document.getElementById('bc' + id);
  if (card) card.classList.toggle('followed', b.fol);
  btn.textContent = b.fol ? '✓ Following' : '+ Follow';
  toast(b.fol ? `🔔 Now following ${b.n}` : `Unfollowed ${b.n}`, b.fol ? 'ok' : '');
}

