<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Navongo's Bridge</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#f0f2f5;--surface:#fff;--surface2:#f8f9fa;--border:#e2e8f0;
  --text:#0f172a;--text2:#475569;--text3:#94a3b8;
  --accent:#0abdc6;--accent-dk:#0891b2;--accent-lt:#e0f8fa;
  --shadow:0 2px 12px rgba(0,0,0,.08);--shadow-lg:0 8px 40px rgba(0,0,0,.14);
  --r:14px;
}
body{font-family:'Inter',sans-serif;background:var(--bg);color:var(--text);min-height:100vh}
a{text-decoration:none;color:inherit}
button{cursor:pointer;font-family:inherit}
input,select,textarea{font-family:inherit}

/* NAV */
nav{position:sticky;top:0;z-index:100;background:rgba(255,255,255,.95);backdrop-filter:blur(12px);border-bottom:1px solid var(--border);height:64px;display:flex;align-items:center;padding:0 24px;gap:16px}
.logo{display:flex;align-items:center;gap:10px;font-weight:800;font-size:1.1rem}
.logo-icon{width:36px;height:36px;background:var(--accent);border-radius:10px;display:flex;align-items:center;justify-content:center;color:#fff;font-size:1rem}
.nav-search{flex:1;max-width:420px;position:relative}
.nav-search input{width:100%;padding:9px 14px 9px 38px;border-radius:50px;border:1.5px solid var(--border);background:var(--surface2);font-size:.85rem;color:var(--text);transition:.2s}
.nav-search input:focus{outline:none;border-color:var(--accent);box-shadow:0 0 0 3px rgba(10,189,198,.15)}
.nav-search-icon{position:absolute;left:12px;top:50%;transform:translateY(-50%);color:var(--text3);font-size:.85rem}
.nav-links{display:flex;gap:4px;margin-left:8px}
.nav-btn{background:none;border:none;padding:7px 14px;border-radius:50px;font-size:.85rem;font-weight:600;color:var(--text2);transition:.2s}
.nav-btn:hover,.nav-btn.active{background:var(--accent-lt);color:var(--accent)}
.nav-right{display:flex;align-items:center;gap:8px;margin-left:auto}
.icon-btn{width:38px;height:38px;border-radius:50%;background:var(--surface2);border:1px solid var(--border);color:var(--text2);font-size:.9rem;display:flex;align-items:center;justify-content:center;position:relative;transition:.2s;cursor:pointer}
.icon-btn:hover{border-color:var(--accent);color:var(--accent)}
.badge{position:absolute;top:-3px;right:-3px;min-width:16px;height:16px;background:var(--accent);color:#fff;font-size:.6rem;font-weight:700;border-radius:8px;display:flex;align-items:center;justify-content:center;padding:0 4px;border:2px solid var(--bg)}
.btn{display:inline-flex;align-items:center;gap:7px;padding:9px 20px;border-radius:50px;font-size:.85rem;font-weight:600;border:none;cursor:pointer;transition:.2s}
.btn-primary{background:var(--accent);color:#fff}
.btn-primary:hover{background:var(--accent-dk);transform:translateY(-1px);box-shadow:0 4px 16px rgba(10,189,198,.35)}
.btn-ghost{background:transparent;border:1.5px solid var(--border);color:var(--text2)}
.btn-ghost:hover{border-color:var(--accent);color:var(--accent)}
.btn-sm{padding:7px 16px;font-size:.8rem}

/* PAGES */
.page{display:none}
.page.active{display:block}

/* TOAST */
#toasts{position:fixed;bottom:24px;right:24px;z-index:9999;display:flex;flex-direction:column;gap:8px}
.toast{background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:12px 18px;box-shadow:var(--shadow-lg);font-size:.84rem;min-width:240px;display:flex;align-items:center;gap:10px;animation:tin .3s ease;border-left:3px solid var(--accent)}
.toast.ok{border-left-color:#10b981}
.toast.err{border-left-color:#ef4444}
@keyframes tin{from{opacity:0;transform:translateX(30px)}to{opacity:1;transform:none}}

/* CANVAS */
#confetti{position:fixed;inset:0;z-index:9998;pointer-events:none;display:none}

/* OVERLAY */
.overlay{position:fixed;inset:0;background:rgba(0,0,0,.5);backdrop-filter:blur(6px);z-index:200;display:none;align-items:center;justify-content:center;padding:16px}
.overlay.open{display:flex}
.modal{background:var(--surface);border-radius:20px;width:100%;max-width:480px;padding:36px;position:relative;animation:mopen .35s cubic-bezier(.34,1.5,.64,1);max-height:90vh;overflow-y:auto}
@keyframes mopen{from{opacity:0;transform:scale(.85) translateY(20px)}to{opacity:1;transform:none}}
.modal-x{position:absolute;top:14px;right:14px;width:32px;height:32px;border-radius:50%;background:var(--surface2);border:none;color:var(--text2);font-size:.9rem;display:flex;align-items:center;justify-content:center;cursor:pointer;transition:.2s}
.modal-x:hover{background:#fee2e2;color:#dc2626}

/* FORM */
.form-group{margin-bottom:16px}
.form-group label{display:block;font-size:.78rem;font-weight:600;color:var(--text2);margin-bottom:5px}
.form-group input,.form-group select,.form-group textarea{width:100%;padding:10px 13px;border-radius:10px;border:1.5px solid var(--border);background:var(--surface2);color:var(--text);font-size:.86rem;transition:.2s}
.form-group input:focus,.form-group select:focus,.form-group textarea:focus{outline:none;border-color:var(--accent);box-shadow:0 0 0 3px rgba(10,189,198,.15)}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:12px}

/* CART DRAWER */
#cart-drawer{position:fixed;right:-400px;top:0;height:100vh;width:380px;background:var(--surface);border-left:1px solid var(--border);z-index:150;display:flex;flex-direction:column;box-shadow:var(--shadow-lg);transition:right .3s ease}
#cart-drawer.open{right:0}
.drawer-head{padding:20px;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center}
.drawer-head h3{font-weight:700;font-size:1rem}
.drawer-body{flex:1;overflow-y:auto;padding:16px}
.drawer-foot{padding:16px;border-top:1px solid var(--border)}
.cart-item{display:flex;gap:10px;padding:12px;background:var(--surface2);border-radius:12px;margin-bottom:10px;position:relative}
.ci-img{width:52px;height:52px;background:var(--bg);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:1.6rem;flex-shrink:0}
.ci-info{flex:1;min-width:0}
.ci-name{font-size:.82rem;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;margin-bottom:3px}
.ci-price{color:var(--accent);font-weight:700;font-size:.88rem}
.ci-rm{position:absolute;top:8px;right:8px;background:none;border:none;color:var(--text3);font-size:.8rem;cursor:pointer;transition:.2s}
.ci-rm:hover{color:#ef4444}
.qty-row{display:flex;align-items:center;gap:6px;margin-top:5px}
.qty-btn{width:20px;height:20px;border-radius:50%;background:var(--bg);border:1px solid var(--border);font-size:.75rem;display:flex;align-items:center;justify-content:center;cursor:pointer;transition:.2s}
.qty-btn:hover{background:var(--accent);color:#fff;border-color:var(--accent)}
.totals{display:flex;flex-direction:column;gap:6px;margin-bottom:14px}
.tot-row{display:flex;justify-content:space-between;font-size:.82rem;color:var(--text2)}
.tot-row.grand{font-size:.95rem;font-weight:700;color:var(--text);border-top:1px solid var(--border);padding-top:8px;margin-top:4px}
.checkout-btn{width:100%;padding:14px;background:linear-gradient(135deg,var(--accent),var(--accent-dk));color:#fff;border:none;border-radius:12px;font-size:.9rem;font-weight:700;cursor:pointer;transition:.2s}
.checkout-btn:hover{opacity:.9;transform:translateY(-1px)}

/* HOME PAGE */
.section{padding:60px 0}
.container{max-width:1300px;margin:0 auto;padding:0 24px}

/* Hero */
.hero{padding:70px 0 50px;position:relative;overflow:hidden}
.hero::before{content:'';position:absolute;top:-100px;right:-100px;width:500px;height:500px;background:radial-gradient(circle,rgba(10,189,198,.12),transparent 70%);pointer-events:none}
.hero-grid{display:grid;grid-template-columns:1fr 1fr;gap:50px;align-items:center}
.hero-kicker{display:inline-flex;align-items:center;gap:8px;background:var(--surface);border:1px solid var(--border);border-radius:50px;padding:5px 14px;font-size:.75rem;font-weight:600;margin-bottom:18px;box-shadow:var(--shadow)}
.hero-dot{width:6px;height:6px;border-radius:50%;background:var(--accent);animation:blink 2s infinite}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.2}}
.hero h1{font-size:clamp(2.2rem,4.5vw,3.6rem);font-weight:800;line-height:1.08;margin-bottom:18px}
.hero h1 span{color:var(--accent)}
.hero p{color:var(--text2);font-size:.95rem;line-height:1.75;max-width:440px;margin-bottom:28px}
.hero-btns{display:flex;gap:12px;flex-wrap:wrap;margin-bottom:32px}
.stats-row{display:flex;gap:24px;padding-top:24px;border-top:1px solid var(--border)}
.stat{display:flex;flex-direction:column}
.stat-val{font-size:1.4rem;font-weight:800}
.stat-lbl{font-size:.72rem;color:var(--text3)}
.hero-cards{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.hc{background:var(--surface);border-radius:12px;padding:14px;border:1px solid var(--border);transition:.3s}
.hc:hover{transform:translateY(-4px);box-shadow:var(--shadow-lg)}
.hc:nth-child(2){margin-top:18px}
.hc:nth-child(3){margin-top:-8px}
.hc-img{background:var(--bg);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:2.4rem;padding:14px;margin-bottom:8px}
.hc-name{font-size:.78rem;font-weight:600;overflow:hidden;white-space:nowrap;text-overflow:ellipsis;margin-bottom:2px}
.hc-price{color:var(--accent);font-weight:700;font-size:.84rem}
.hc-src{font-size:.68rem;color:var(--text3)}

/* Platform strip */
.plat-strip{background:var(--surface);border-top:1px solid var(--border);border-bottom:1px solid var(--border);padding:20px 0}
.plat-inner{display:flex;align-items:center;justify-content:center;gap:36px;flex-wrap:wrap}
.plat-item{display:flex;align-items:center;gap:8px;font-size:.84rem;font-weight:700;opacity:.45;transition:.2s;cursor:default}
.plat-item:hover{opacity:1}
.plat-ico{width:26px;height:26px;border-radius:7px;display:flex;align-items:center;justify-content:center;font-size:.85rem}

/* Advantages */
.adv-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:16px;margin-top:36px}
.adv-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--r);padding:22px;transition:.25s}
.adv-card:hover{transform:translateY(-3px);box-shadow:var(--shadow-lg);border-color:var(--accent)}
.adv-icon{font-size:1.6rem;margin-bottom:10px}
.adv-title{font-weight:700;font-size:.9rem;margin-bottom:4px}
.adv-desc{font-size:.78rem;color:var(--text2);line-height:1.6}

/* Categories */
.cat-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(120px,1fr));gap:10px;margin-top:24px}
.cat-card{background:var(--surface);border:1.5px solid var(--border);border-radius:12px;padding:16px 10px;text-align:center;cursor:pointer;transition:.2s}
.cat-card:hover,.cat-card.sel{border-color:var(--accent);background:var(--accent-lt)}
.cat-em{font-size:1.6rem;margin-bottom:6px}
.cat-nm{font-size:.78rem;font-weight:700}
.cat-ct{font-size:.65rem;color:var(--text3);margin-top:2px}
.subcat-row{display:flex;gap:8px;flex-wrap:wrap;margin-top:12px;margin-bottom:24px}
.sc{padding:5px 14px;border-radius:50px;border:1.5px solid var(--border);font-size:.78rem;cursor:pointer;background:var(--surface);transition:.2s}
.sc:hover,.sc.sel{background:var(--accent);color:#fff;border-color:var(--accent)}

/* Products */
.toolbar{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;margin-bottom:20px}
.filters{display:flex;gap:6px;flex-wrap:wrap}
.filter-btn{padding:6px 14px;border-radius:50px;border:1.5px solid var(--border);font-size:.76rem;font-weight:600;background:var(--surface);cursor:pointer;transition:.2s}
.filter-btn:hover,.filter-btn.sel{border-color:var(--accent);color:var(--accent)}
.sort-sel{padding:7px 12px;border-radius:50px;border:1.5px solid var(--border);background:var(--surface2);font-size:.78rem;color:var(--text)}
.sort-sel:focus{outline:none}
.prod-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:16px}

/* 3D Product Card */
.pc{background:var(--surface);border:1.5px solid var(--border);border-radius:var(--r);overflow:hidden;cursor:pointer;transition:border-color .2s,box-shadow .2s;perspective:800px}
.pc:hover{border-color:rgba(10,189,198,.4);box-shadow:0 16px 48px rgba(0,0,0,.16)}
.pc-inner{transition:transform .08s linear;border-radius:var(--r);overflow:hidden}
.pc-glow{position:absolute;inset:0;border-radius:var(--r);pointer-events:none;opacity:0;transition:opacity .3s;background:radial-gradient(circle at var(--gx,50%) var(--gy,50%),rgba(10,189,198,.18),transparent 65%);z-index:1}
.pc:hover .pc-glow{opacity:1}
.pc-img-wrap{position:relative;aspect-ratio:1;background:var(--bg);display:flex;align-items:center;justify-content:center;font-size:3.2rem;overflow:hidden}
.pc-emoji{display:inline-block;transition:transform .3s cubic-bezier(.34,1.5,.64,1)}
.pc:hover .pc-emoji{transform:scale(1.2) rotate(-6deg)}
.src-tag{position:absolute;top:8px;left:8px;padding:2px 8px;border-radius:5px;font-size:.62rem;font-weight:800;color:#fff}
.wish-btn{position:absolute;top:8px;right:8px;width:28px;height:28px;border-radius:50%;background:var(--surface);border:none;font-size:.8rem;display:flex;align-items:center;justify-content:center;cursor:pointer;box-shadow:var(--shadow);z-index:2;transition:.2s}
.wish-btn:hover{transform:scale(1.15)}
.pc-body{padding:12px;position:relative;z-index:1}
.pc-brand{font-size:.67rem;color:var(--text3);font-weight:600;text-transform:uppercase;letter-spacing:.04em;margin-bottom:2px}
.pc-name{font-size:.84rem;font-weight:700;margin-bottom:6px;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
.pc-stars{color:#f59e0b;font-size:.72rem;margin-bottom:6px}
.pc-stars span{color:var(--text3);font-size:.68rem;margin-left:3px}
.pc-foot{display:flex;align-items:center;justify-content:space-between}
.pc-price{font-size:1rem;font-weight:800;color:var(--accent)}
.pc-orig{font-size:.72rem;color:var(--text3);text-decoration:line-through;margin-top:1px}
.add-btn{width:32px;height:32px;border-radius:8px;background:var(--accent);border:none;color:#fff;font-size:.88rem;display:flex;align-items:center;justify-content:center;cursor:pointer;transition:.2s}
.add-btn:hover{background:var(--accent-dk);transform:scale(1.1)}

/* Item Detail Modal */
.item-modal{max-width:700px;padding:0;overflow:hidden;display:grid;grid-template-columns:1fr 1fr}
.im-left{background:var(--bg);display:flex;align-items:center;justify-content:center;padding:40px;position:relative;min-height:280px}
.im-left::before{content:'';position:absolute;inset:0;background:radial-gradient(circle,var(--accent-lt),transparent 70%)}
.im-emoji{font-size:6rem;position:relative;z-index:1;animation:em-float 3s ease-in-out infinite}
@keyframes em-float{0%,100%{transform:translateY(0) rotate(-4deg) scale(1)}50%{transform:translateY(-14px) rotate(4deg) scale(1.08)}}
.im-right{padding:28px;overflow-y:auto;max-height:80vh}
.im-src{display:inline-block;padding:3px 10px;border-radius:6px;font-size:.72rem;font-weight:800;color:#fff;margin-bottom:10px}
.im-name{font-size:1.25rem;font-weight:800;line-height:1.2;margin-bottom:6px}
.im-stars{color:#f59e0b;font-size:.82rem;margin-bottom:12px}
.im-price{font-size:1.8rem;font-weight:800;color:var(--accent);margin-bottom:2px}
.im-orig{font-size:.82rem;color:var(--text3);text-decoration:line-through;margin-bottom:14px}
.im-desc{font-size:.82rem;color:var(--text2);line-height:1.7;margin-bottom:16px}
.im-tags{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:18px}
.im-tag{padding:3px 10px;background:var(--accent-lt);color:var(--accent-dk);border-radius:50px;font-size:.7rem;font-weight:600}
.im-actions{display:flex;gap:10px;align-items:center}
.qty-control{display:flex;align-items:center;gap:8px;background:var(--bg);border-radius:10px;padding:7px 12px}
.qty-control button{width:24px;height:24px;border-radius:50%;background:var(--accent);color:#fff;border:none;font-size:.85rem;cursor:pointer;transition:.2s}
.qty-control button:hover{background:var(--accent-dk)}
.qty-control span{font-weight:700;min-width:20px;text-align:center}

/* Referral banner */
.ref-banner{background:linear-gradient(135deg,var(--accent),var(--accent-dk));border-radius:18px;padding:28px 32px;display:flex;align-items:center;justify-content:space-between;gap:20px;flex-wrap:wrap;color:#fff;margin:40px 0}
.ref-left h3{font-size:1.25rem;font-weight:800;margin-bottom:4px}
.ref-left p{font-size:.82rem;opacity:.9}
.ref-box{background:rgba(255,255,255,.18);border-radius:10px;padding:12px 18px;display:flex;align-items:center;gap:12px}
.ref-code{font-size:1.1rem;font-weight:800;letter-spacing:.07em}
.ref-copy-btn{background:rgba(255,255,255,.25);border:none;color:#fff;padding:6px 14px;border-radius:8px;font-size:.76rem;font-weight:700;cursor:pointer;transition:.2s}
.ref-copy-btn:hover{background:rgba(255,255,255,.4)}

/* Section headers */
.sec-kicker{font-size:.7rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--accent);margin-bottom:4px}
.sec-title{font-size:clamp(1.5rem,2.5vw,2.2rem);font-weight:800;line-height:1.15}

/* SCROLL ANIMATIONS */
.reveal{opacity:0;transform:translateY(28px);transition:opacity .65s ease,transform .65s ease}
.reveal-left{opacity:0;transform:translateX(-28px);transition:opacity .65s ease,transform .65s ease}
.reveal-right{opacity:0;transform:translateX(28px);transition:opacity .65s ease,transform .65s ease}
.reveal-scale{opacity:0;transform:scale(.9);transition:opacity .65s ease,transform .65s ease}
.revealed{opacity:1 !important;transform:none !important}
.d1{transition-delay:.1s}.d2{transition-delay:.2s}.d3{transition-delay:.3s}.d4{transition-delay:.4s}.d5{transition-delay:.5s}

/* PAYMENT MODAL */
.pay-methods{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin:14px 0}
.pm{padding:10px;border-radius:10px;border:1.5px solid var(--border);background:var(--surface2);text-align:center;cursor:pointer;transition:.2s}
.pm:hover,.pm.sel{border-color:var(--accent);background:var(--accent-lt)}
.pm-icon{font-size:1.2rem;margin-bottom:3px}
.pm-lbl{font-size:.72rem;font-weight:700}
.pay-steps{display:flex;gap:5px;margin-bottom:22px}
.pay-step{flex:1;height:4px;border-radius:2px;background:var(--border)}
.pay-step.on{background:var(--accent)}

/* RATING MODAL */
.stars-row{display:flex;gap:8px;margin-bottom:14px}
.stars-row span{font-size:1.6rem;cursor:pointer;transition:.15s;opacity:.3}
.stars-row span.lit{opacity:1}

/* AUTH PAGE */
.auth-page{min-height:calc(100vh - 64px);display:flex;align-items:center;justify-content:center;padding:40px 24px}
.auth-wrap{display:grid;grid-template-columns:1fr 1.1fr;max-width:960px;width:100%;border-radius:22px;overflow:hidden;box-shadow:var(--shadow-lg)}
.auth-left{background:linear-gradient(145deg,#0891b2,#0abdc6,#7c3aed);padding:48px 40px;color:#fff;display:flex;flex-direction:column;justify-content:space-between}
.auth-left h2{font-size:1.9rem;font-weight:800;line-height:1.2;margin-bottom:12px}
.auth-left p{font-size:.86rem;opacity:.9;line-height:1.7;max-width:270px}
.auth-perks{list-style:none;margin-top:28px;display:flex;flex-direction:column;gap:10px}
.auth-perks li{font-size:.82rem;display:flex;align-items:center;gap:9px;opacity:.92}
.auth-perks li::before{content:'✓';width:18px;height:18px;background:rgba(255,255,255,.25);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:.7rem;font-weight:700;flex-shrink:0}
.auth-right{background:var(--surface);padding:44px 40px;overflow-y:auto;max-height:100vh}
.auth-tabs{display:flex;background:var(--bg);border-radius:10px;padding:3px;margin-bottom:26px}
.auth-tab{flex:1;padding:8px;border-radius:8px;border:none;font-size:.83rem;font-weight:600;color:var(--text2);background:transparent;cursor:pointer;transition:.2s}
.auth-tab.active{background:var(--surface);color:var(--text);box-shadow:var(--shadow)}

/* Multi-step progress */
.steps-bar{display:flex;align-items:center;margin-bottom:26px;gap:0}
.step-node{display:flex;flex-direction:column;align-items:center;flex-shrink:0}
.step-circle{width:28px;height:28px;border-radius:50%;border:2px solid var(--border);background:var(--surface);font-size:.72rem;font-weight:700;color:var(--text3);display:flex;align-items:center;justify-content:center;transition:.25s}
.step-circle.active{border-color:var(--accent);background:var(--accent);color:#fff}
.step-circle.done{border-color:var(--accent);background:var(--accent-lt);color:var(--accent)}
.step-label{font-size:.62rem;font-weight:600;color:var(--text3);margin-top:4px;white-space:nowrap}
